{
  "version": "1.0",
  "description": "Benchmark threshold configuration for CI regression detection (hosted-runner profile)",
  "thresholds": {
    "indexing": {
      "indexTimePerFile": {
        "maxMs": 350,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 15,
        "_comment": "Raised from 220 ms (v0.6.9b): canonical-test BFS is now O(edges) via batch pass, but CI runner variance warrants ~75 % headroom above the ~198 ms zod-oss baseline."
      },
      "indexTimePerSymbol": {
        "maxMs": 20,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 60,
        "_comment": "Raised from 15 ms: TS call-resolver adds per-symbol resolution work. Absolute cap still guards against catastrophic regressions."
      }
    },
    "quality": {
      "symbolsPerFile": {
        "minValue": 5,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 5
      },
      "edgesPerSymbol": {
        "minValue": 1,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 5
      },
      "graphConnectivity": {
        "minValue": 0.3,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 5
      },
      "exportedSymbolRatio": {
        "minValue": 0.2,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 15,
        "_comment": "Widened from 10 %: TS call-resolver indexes more internal helper symbols (alias targets, barrel re-exports), which legitimately dilutes the exported ratio."
      }
    },
    "performance": {
      "sliceBuildTimeMs": {
        "maxMs": 350,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 125,
        "_comment": "Raised from 200 ms: TS call-resolver creates more edges (import aliases, barrel re-exports), making graph loading and beam-search proportionally slower."
      },
      "avgSkeletonTimeMs": {
        "maxMs": 5,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 30
      }
    },
    "tokenEfficiency": {
      "avgCardTokens": {
        "maxTokens": 350,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 30
      },
      "avgSkeletonTokens": {
        "maxTokens": 200,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 10
      }
    },
    "coverage": {
      "callEdgeCoverage": {
        "minPercent": 0.1,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 10
      },
      "importEdgeCoverage": {
        "minPercent": 0.5,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 10
      }
    }
  },
  "smoothing": {
    "warmupRuns": 2,
    "sampleRuns": 3,
    "outlierMethod": "iqr",
    "iqrMultiplier": 1.5
  },
  "baseline": {
    "filePath": ".benchmark/baseline.zod-oss.json",
    "autoUpdateOnPass": false
  }
}
