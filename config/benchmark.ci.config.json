{
  "version": "1.0",
  "description": "Benchmark threshold configuration for CI regression detection (hosted-runner profile)",
  "thresholds": {
    "indexing": {
      "indexTimePerFile": {
        "maxMs": 2500,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 30,
        "_comment": "Raised for LadybugDB graph backend: graph writes are inherently slower than SQLite inserts. CI runners see ~1500-1700ms per file."
      },
      "indexTimePerSymbol": {
        "maxMs": 150,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 30,
        "_comment": "Raised for LadybugDB graph backend: per-symbol graph operations cost more than SQLite row inserts."
      }
    },
    "quality": {
      "symbolsPerFile": {
        "minValue": 5,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 5
      },
      "edgesPerSymbol": {
        "minValue": 1,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 5
      },
      "graphConnectivity": {
        "minValue": 0.3,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 5
      },
      "exportedSymbolRatio": {
        "minValue": 0.2,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 15,
        "_comment": "Widened from 10 %: TS call-resolver indexes more internal helper symbols (alias targets, barrel re-exports), which legitimately dilutes the exported ratio."
      }
    },
    "performance": {
      "sliceBuildTimeMs": {
        "maxMs": 350,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 125,
        "_comment": "Raised from 200 ms: TS call-resolver creates more edges (import aliases, barrel re-exports), making graph loading and beam-search proportionally slower."
      },
      "avgSkeletonTimeMs": {
        "maxMs": 10,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 50
      }
    },
    "tokenEfficiency": {
      "avgCardTokens": {
        "maxTokens": 350,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 30
      },
      "avgSkeletonTokens": {
        "maxTokens": 200,
        "trend": "lower-is-better",
        "allowableIncreasePercent": 10
      }
    },
    "coverage": {
      "callEdgeCoverage": {
        "minPercent": 0.1,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 10
      },
      "importEdgeCoverage": {
        "minPercent": 0.5,
        "trend": "higher-is-better",
        "allowableDecreasePercent": 10
      }
    }
  },
  "smoothing": {
    "warmupRuns": 0,
    "sampleRuns": 2,
    "outlierMethod": "iqr",
    "iqrMultiplier": 1.5
  },
  "baseline": {
    "filePath": ".benchmark/baseline.zod-oss.json",
    "autoUpdateOnPass": false
  }
}
