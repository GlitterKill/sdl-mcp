{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SDL-MCP Configuration",
  "description": "Configuration schema for SDL-MCP (Symbol Delta Ledger MCP Server)",
  "type": "object",
  "required": ["repos", "policy"],
  "properties": {
    "repos": {
      "type": "array",
      "description": "List of repositories to index",
      "items": {
        "type": "object",
        "required": ["repoId", "rootPath"],
        "properties": {
          "repoId": {
            "type": "string",
            "description": "Unique identifier for the repository",
            "minLength": 1
          },
          "rootPath": {
            "type": "string",
            "description": "Absolute or relative path to the repository root",
            "minLength": 1
          },
          "ignore": {
            "type": "array",
            "description": "Glob patterns to ignore during indexing",
            "items": {
              "type": "string"
            },
            "default": [
              "**/.git/**",
              "**/dist/**",
              "**/dist-*/**",
              "**/build/**",
              "**/out/**",
              "**/target/**",
              "**/coverage/**",
              "**/node_modules/**",
              "**/vendor/**",
              "**/.next/**",
              "**/__pycache__/**",
              "**/.venv/**",
              "**/.tmp/**",
              "**/.claude/**",
              "**/.sdl-memory/**"
            ]
          },
          "languages": {
            "type": "array",
            "description": "Programming languages to index",
            "items": {
              "type": "string",
              "enum": [
                "ts",
                "tsx",
                "js",
                "jsx",
                "py",
                "go",
                "java",
                "cs",
                "c",
                "cpp",
                "php",
                "rs",
                "kt",
                "sh"
              ]
            },
            "default": [
              "ts",
              "tsx",
              "js",
              "jsx",
              "py",
              "go",
              "java",
              "cs",
              "c",
              "cpp",
              "php",
              "rs",
              "kt",
              "sh"
            ]
          },
          "maxFileBytes": {
            "type": "integer",
            "description": "Maximum file size in bytes to index",
            "minimum": 1,
            "default": 2000000
          },
          "includeNodeModulesTypes": {
            "type": "boolean",
            "description": "Include node_modules/@types declarations in TypeScript call resolution (excluding @types/node)",
            "default": true
          },
          "packageJsonPath": {
            "type": "string",
            "description": "Optional path to package.json (auto-detected if not provided)"
          },
          "tsconfigPath": {
            "type": "string",
            "description": "Optional path to tsconfig.json (auto-detected if not provided)"
          },
          "workspaceGlobs": {
            "type": "array",
            "description": "Glob patterns to find workspace package.json files (monorepo support)",
            "items": {
              "type": "string"
            }
          },
          "memory": {
            "type": "object",
            "description": "Memory subsystem configuration. Memory is disabled by default.",
            "properties": {
              "enabled": {
                "type": "boolean",
                "description": "Master enable for the memory subsystem. When false, all memory features are disabled.",
                "default": false
              },
              "toolsEnabled": {
                "type": "boolean",
                "description": "Enable memory CRUD tools (store, query, remove, surface)",
                "default": true
              },
              "fileSyncEnabled": {
                "type": "boolean",
                "description": "Enable .sdl-memory file read/import/write/delete",
                "default": true
              },
              "surfacingEnabled": {
                "type": "boolean",
                "description": "Enable memory injection into repo.status and slice.build",
                "default": true
              },
              "hintsEnabled": {
                "type": "boolean",
                "description": "Enable _memoryHint post-dispatch guidance",
                "default": true
              },
              "defaultSurfaceLimit": {
                "type": "integer",
                "description": "Default number of memories to surface when limit is omitted",
                "default": 5,
                "minimum": 1,
                "maximum": 50
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "performanceTier": {
      "type": "string",
      "description": "CPU performance tier for auto-tuning concurrency defaults. 'auto' (default) detects hardware at startup. 'mid' = 1-8 cores (conservative), 'high' = 9-20 cores (moderate), 'extreme' = 21+ cores (aggressive). Presets only affect fields not explicitly set by the user.",
      "enum": ["mid", "high", "extreme", "auto"],
      "default": "auto"
    },
    "policy": {
      "type": "object",
      "description": "Code access policy settings",
      "properties": {
        "maxWindowLines": {
          "type": "integer",
          "description": "Maximum lines of code to return per window",
          "minimum": 1,
          "default": 180
        },
        "maxWindowTokens": {
          "type": "integer",
          "description": "Maximum tokens to return per window",
          "minimum": 1,
          "default": 1400
        },
        "requireIdentifiers": {
          "type": "boolean",
          "description": "Require user to specify identifiers before returning code",
          "default": true
        },
        "allowBreakGlass": {
          "type": "boolean",
          "description": "Allow break-glass mode to override policy temporarily",
          "default": false
        },
        "defaultMinCallConfidence": {
          "type": "number",
          "description": "Optional default minCallConfidence for symbol-card and slice call-edge filtering",
          "minimum": 0,
          "maximum": 1
        },
        "defaultDenyRaw": {
          "type": "boolean",
          "description": "Default deny for raw code windows — subjects needWindow requests to proof-of-need gating (symbol in slice, identifiers provided, reason given)",
          "default": true
        }
      },
      "default": {
        "maxWindowLines": 180,
        "maxWindowTokens": 1400,
        "requireIdentifiers": true,
        "allowBreakGlass": false,
        "defaultDenyRaw": true
      }
    },
    "redaction": {
      "type": "object",
      "description": "Secret redaction configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable secret redaction",
          "default": true
        },
        "includeDefaults": {
          "type": "boolean",
          "description": "Include default redaction patterns",
          "default": true
        },
        "patterns": {
          "type": "array",
          "description": "Custom redaction patterns",
          "items": {
            "type": "object",
            "required": ["pattern"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Pattern name for documentation"
              },
              "pattern": {
                "type": "string",
                "description": "Regex pattern to match",
                "minLength": 1
              },
              "flags": {
                "type": "string",
                "description": "Regex flags (e.g., 'i', 'g', 'm')"
              }
            }
          },
          "default": []
        }
      },
      "default": {
        "enabled": true,
        "includeDefaults": true,
        "patterns": []
      }
    },
    "indexing": {
      "type": "object",
      "description": "Indexing behavior configuration",
      "properties": {
        "concurrency": {
          "type": "integer",
          "description": "Number of concurrent indexing workers",
          "minimum": 1,
          "maximum": 32,
          "default": 8
        },
        "enableFileWatching": {
          "type": "boolean",
          "description": "Enable automatic reindexing on file changes",
          "default": true
        },
        "maxWatchedFiles": {
          "type": "integer",
          "description": "Maximum candidate source files allowed for watcher startup",
          "minimum": 1,
          "default": 25000
        },
        "workerPoolSize": {
          "type": "integer",
          "description": "Optional cap for the indexing worker pool size",
          "minimum": 1,
          "maximum": 32
        },
        "engine": {
          "type": "string",
          "description": "Pass-1 indexing engine implementation",
          "enum": ["typescript", "rust"],
          "default": "rust"
        },
        "watchDebounceMs": {
          "type": "integer",
          "description": "Debounce delay in milliseconds for file watch events",
          "minimum": 50,
          "maximum": 5000,
          "default": 300
        },
        "pass2Concurrency": {
          "type": "integer",
          "description": "Number of files to resolve concurrently in Pass 2 cross-file call resolution. Default 1 (sequential). Increase on multi-core systems to overlap CPU parse work with read I/O.",
          "minimum": 1,
          "maximum": 16,
          "default": 1
        }
      },
      "default": {
        "concurrency": 8,
        "enableFileWatching": true,
        "maxWatchedFiles": 25000,
        "engine": "rust",
        "watchDebounceMs": 300,
        "pass2Concurrency": 1
      }
    },
    "liveIndex": {
      "type": "object",
      "description": "Live editor-buffer indexing and overlay reconciliation settings",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable live buffer indexing and draft-aware reads",
          "default": true
        },
        "debounceMs": {
          "type": "integer",
          "description": "Debounce delay in milliseconds for editor buffer parse work",
          "minimum": 25,
          "maximum": 5000,
          "default": 75
        },
        "idleCheckpointMs": {
          "type": "integer",
          "description": "Quiet-period threshold in milliseconds before idle checkpoint compaction runs",
          "minimum": 1000,
          "maximum": 600000,
          "default": 15000
        },
        "maxDraftFiles": {
          "type": "integer",
          "description": "Maximum number of in-memory draft files allowed per repo",
          "minimum": 1,
          "maximum": 10000,
          "default": 200
        },
        "reconcileConcurrency": {
          "type": "integer",
          "description": "Reserved concurrency cap for background reconciliation work",
          "minimum": 1,
          "maximum": 16,
          "default": 1
        },
        "clusterRefreshThreshold": {
          "type": "integer",
          "description": "Touched-symbol threshold that should trigger broader cluster/process refresh behavior",
          "minimum": 1,
          "maximum": 1000,
          "default": 25
        }
      },
      "default": {
        "enabled": true,
        "debounceMs": 75,
        "idleCheckpointMs": 15000,
        "maxDraftFiles": 200,
        "reconcileConcurrency": 1,
        "clusterRefreshThreshold": 25
      }
    },
    "slice": {
      "type": "object",
      "description": "Graph slice configuration",
      "properties": {
        "defaultMaxCards": {
          "type": "integer",
          "description": "Default maximum cards in a slice",
          "minimum": 1,
          "default": 60
        },
        "defaultMaxTokens": {
          "type": "integer",
          "description": "Default maximum tokens in a slice",
          "minimum": 1,
          "default": 12000
        },
        "edgeWeights": {
          "type": "object",
          "description": "Weights for different edge types in slice traversal",
          "properties": {
            "call": {
              "type": "number",
              "description": "Weight for call edges",
              "minimum": 0,
              "default": 1
            },
            "import": {
              "type": "number",
              "description": "Weight for import edges",
              "minimum": 0,
              "default": 0.6
            },
            "config": {
              "type": "number",
              "description": "Weight for config edges",
              "minimum": 0,
              "default": 0.8
            }
          },
          "default": {
            "call": 1,
            "import": 0.6,
            "config": 0.8
          }
        }
      },
      "default": {
        "defaultMaxCards": 60,
        "defaultMaxTokens": 12000,
        "edgeWeights": {
          "call": 1,
          "import": 0.6,
          "config": 0.8
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "description": "TypeScript diagnostics configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable TypeScript diagnostics",
          "default": true
        },
        "mode": {
          "type": "string",
          "description": "Diagnostics mode",
          "enum": ["tsLS", "tsc"],
          "default": "tsLS"
        },
        "maxErrors": {
          "type": "integer",
          "description": "Maximum errors to report per file",
          "minimum": 1,
          "default": 50
        },
        "timeoutMs": {
          "type": "integer",
          "description": "Timeout for diagnostics in milliseconds",
          "minimum": 100,
          "default": 2000
        },
        "scope": {
          "type": "string",
          "description": "Diagnostics scope",
          "enum": ["changedFiles", "workspace"],
          "default": "changedFiles"
        }
      },
      "default": {
        "enabled": true,
        "mode": "tsLS",
        "maxErrors": 50,
        "timeoutMs": 2000,
        "scope": "changedFiles"
      }
    },
    "cache": {
      "type": "object",
      "description": "In-memory caching configuration for symbol cards and slices",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable caching",
          "default": true
        },
        "symbolCardMaxEntries": {
          "type": "integer",
          "description": "Maximum number of symbol cards to keep in cache",
          "minimum": 1,
          "default": 2000
        },
        "symbolCardMaxSizeBytes": {
          "type": "integer",
          "description": "Maximum total size in bytes for cached symbol cards",
          "minimum": 1024,
          "default": 104857600
        },
        "graphSliceMaxEntries": {
          "type": "integer",
          "description": "Maximum number of graph slices to keep in cache",
          "minimum": 1,
          "default": 1000
        },
        "graphSliceMaxSizeBytes": {
          "type": "integer",
          "description": "Maximum total size in bytes for cached graph slices",
          "minimum": 1024,
          "default": 52428800
        }
      },
      "default": {
        "enabled": true,
        "symbolCardMaxEntries": 2000,
        "symbolCardMaxSizeBytes": 104857600,
        "graphSliceMaxEntries": 1000,
        "graphSliceMaxSizeBytes": 52428800
      }
    },
    "plugins": {
      "type": "object",
      "description": "Adapter plugin configuration",
      "properties": {
        "paths": {
          "type": "array",
          "description": "Paths to plugin entrypoints (files or directories)",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "enabled": {
          "type": "boolean",
          "description": "Enable plugin loading",
          "default": true
        },
        "strictVersioning": {
          "type": "boolean",
          "description": "Require plugin API version compatibility",
          "default": true
        }
      },
      "default": {
        "paths": [],
        "enabled": true,
        "strictVersioning": true
      }
    },
    "semantic": {
      "type": "object",
      "description": "Semantic retrieval and generated summary configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable semantic reranking in symbol search",
          "default": true
        },
        "provider": {
          "type": "string",
          "enum": ["api", "local", "mock"],
          "default": "local"
        },
        "model": {
          "type": "string",
          "enum": ["jina-embeddings-v2-base-code", "nomic-embed-text-v1.5"],
          "default": "jina-embeddings-v2-base-code"
        },
        "additionalModels": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["nomic-embed-text-v1.5"],
          "description": "Extra embedding models to populate at index time so multiple vector lanes can contribute to hybrid fusion. Primary `model` is always populated; each name listed here gets a separate pass. Unknown model names are skipped."
        },
        "modelCacheDir": {
          "type": "string",
          "description": "Override directory for downloaded model files (nomic-embed-text-v1.5). Defaults to platform-specific cache."
        },
        "generateSummaries": {
          "type": "boolean",
          "default": false
        },
        "summaryProvider": {
          "type": "string",
          "enum": ["api", "local", "mock"],
          "description": "Summary LLM backend, independent from the embedding provider. 'api' = Anthropic, 'local' = OpenAI-compatible (Ollama), 'mock' = deterministic. Defaults to the embedding 'provider' value."
        },
        "summaryModel": {
          "type": "string",
          "description": "Model name for summary generation. Defaults per-provider: 'api' uses 'claude-haiku-4-5-20251001', 'local' uses 'gpt-4o-mini'."
        },
        "summaryApiKey": {
          "type": "string",
          "description": "API key for the summary LLM provider. Falls back to ANTHROPIC_API_KEY environment variable."
        },
        "summaryApiBaseUrl": {
          "type": "string",
          "description": "Base URL for OpenAI-compatible local providers (e.g., http://localhost:11434 for Ollama)"
        },
        "summaryMaxConcurrency": {
          "type": "integer",
          "description": "Maximum concurrent LLM requests for summary generation",
          "minimum": 1,
          "maximum": 32,
          "default": 5
        },
        "summaryBatchSize": {
          "type": "integer",
          "description": "Number of symbols to batch per summary generation pass",
          "minimum": 1,
          "maximum": 50,
          "default": 20
        },
        "embeddingConcurrency": {
          "type": "integer",
          "description": "Number of embedding batches to process concurrently during refreshSymbolEmbeddings(). Defaults to 1 (sequential). Increasing this can improve throughput on multi-core machines but ONNX Runtime's internal thread pool is shared across concurrent calls; consider reducing intraOpNumThreads proportionally when raising above 1. Maximum 8.",
          "minimum": 1,
          "maximum": 8,
          "default": 1
        },
        "embeddingBatchSize": {
          "type": "integer",
          "description": "ONNX inference batch width for symbol embedding refresh. Default 32 matches LocalEmbeddingProvider's tokenizer + session expectations. Larger batches (64-128) amortise tokenizer + session bind/unbind costs across more rows but raise peak memory roughly with the longest sequence in the batch. Length-bucketing before splitting keeps tokenizer pad waste bounded.",
          "minimum": 1,
          "maximum": 128,
          "default": 32
        },
        "embeddingsSequential": {
          "type": "boolean",
          "description": "When two or more embedding models are configured, run them in series instead of via Promise.all. Default false launches concurrently — best when ORT runs sessions on independent thread pools. Set true on systems where ORT serializes sessions at the thread-pool layer (observed alternation pattern in CLI progress); each model holds the full thread budget end-to-end, weights stay hot in L3 cache, and model-handoff scheduling overhead disappears.",
          "default": false
        },
        "modelVariant": {
          "type": "string",
          "description": "ONNX model file variant to load. Common values: 'default' / 'int8' (~140-160MB, balanced), 'fp16' (~270-320MB, ~30% faster than fp32 with <0.5% accuracy loss), 'fp32' (~550-650MB, reference quality). nomic-embed-text-v1.5 also publishes 'uint8', 'q4', 'q4f16', 'bnb4'. When the chosen variant is not published for a given model, the registry falls back to that model's default variant with a warning."
        },
        "executionProviders": {
          "type": "array",
          "items": { "type": "string" },
          "description": "ONNX Runtime execution providers in priority order. ORT tries them left-to-right; first one that initialises wins. Bundled with default onnxruntime-node npm package: Windows x64 ['cpu', 'dml', 'webgpu'], macOS ['cpu', 'coreml'], Linux x64 ['cpu', 'cuda', 'tensorrt'] (CUDA EP requires NVIDIA GPU + CUDA 12 + cuDNN on the host), Linux arm64 ['cpu']. DirectML covers any DX12 GPU including AMD Radeon, NVIDIA GeForce, Intel Arc. ROCm (AMD on Linux), OpenVINO, QNN need a custom ORT build. Unsupported entries on a given platform are dropped with a warning; 'cpu' is auto-appended as final fallback so session creation never strands.",
          "default": ["cpu"]
        },
        "ann": {
          "type": "object",
          "description": "Deprecated — removed in v0.10.1. Silently ignored. Use retrieval.vector instead.",
          "properties": {
            "enabled": { "type": "boolean" },
            "m": { "type": "integer" },
            "efConstruction": { "type": "integer" },
            "efSearch": { "type": "integer" },
            "maxElements": { "type": "integer" }
          }
        },
        "retrieval": {
          "type": "object",
          "description": "Hybrid retrieval pipeline configuration (FTS + vector fusion). Controls the new two-stage retrieval path that replaces legacy embedding re-ranking.",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["legacy", "hybrid"],
              "default": "hybrid",
              "description": "'legacy' = original semantic-only re-rank path; 'hybrid' = FTS + vector fusion pipeline."
            },
            "extensionsOptional": {
              "type": "boolean",
              "default": true,
              "description": "When true, file-extension filtering is optional (not enforced) during retrieval."
            },
            "fts": {
              "type": "object",
              "description": "Full-text search (FTS) stage configuration.",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true,
                  "description": "Enable the FTS retrieval stage."
                },
                "indexName": {
                  "type": "string",
                  "default": "symbol_search_text_v1",
                  "description": "Name of the FTS index to query."
                },
                "topK": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 75,
                  "description": "Maximum candidates to retrieve from FTS before fusion."
                },
                "conjunctive": {
                  "type": "boolean",
                  "default": false,
                  "description": "When true, require all query terms to match (AND mode). Default is disjunctive (OR mode)."
                }
              },
              "default": {
                "enabled": true,
                "indexName": "symbol_search_text_v1",
                "topK": 75,
                "conjunctive": false
              }
            },
            "vector": {
              "type": "object",
              "description": "Vector (HNSW) retrieval stage configuration.",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true,
                  "description": "Enable the vector retrieval stage."
                },
                "topK": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 75,
                  "description": "Maximum candidates to retrieve from the vector index before fusion."
                },
                "efc": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 200,
                  "description": "HNSW ef_construction parameter for index build time."
                },
                "efs": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 200,
                  "description": "HNSW efSearch parameter — size of the dynamic candidate list during search."
                },
                "indexes": {
                  "type": "object",
                  "description": "Per-model HNSW index config keyed by model name.",
                  "additionalProperties": {
                    "type": "object",
                    "required": ["indexName"],
                    "properties": {
                      "indexName": {
                        "type": "string",
                        "description": "Name of the HNSW index for this model."
                      }
                    }
                  },
                  "default": {
                    "jina-embeddings-v2-base-code": {
                      "indexName": "symbol_vec_jina_code_v2"
                    },
                    "nomic-embed-text-v1.5": {
                      "indexName": "symbol_vec_nomic_embed_v15"
                    }
                  }
                }
              },
              "default": {
                "enabled": true,
                "topK": 75,
                "efs": 200,
                "indexes": {
                  "jina-embeddings-v2-base-code": {
                    "indexName": "symbol_vec_jina_code_v2"
                  },
                  "nomic-embed-text-v1.5": {
                    "indexName": "symbol_vec_nomic_embed_v15"
                  }
                }
              }
            },
            "fusion": {
              "type": "object",
              "description": "Score fusion configuration for combining FTS and vector results.",
              "properties": {
                "strategy": {
                  "type": "string",
                  "enum": ["rrf"],
                  "default": "rrf",
                  "description": "Fusion strategy. 'rrf' = Reciprocal Rank Fusion."
                },
                "rrfK": {
                  "type": "integer",
                  "minimum": 1,
                  "default": 60,
                  "description": "RRF k parameter — controls the influence of rank position. Higher values reduce the impact of top ranks."
                }
              },
              "default": {
                "strategy": "rrf",
                "rrfK": 60
              }
            },
            "candidateLimit": {
              "type": "integer",
              "minimum": 1,
              "default": 100,
              "description": "Maximum candidate symbols to collect from all retrieval stages before fusion re-ranking."
            }
          },
          "default": {
            "mode": "hybrid",
            "extensionsOptional": true,
            "fts": {
              "enabled": true,
              "indexName": "symbol_search_text_v1",
              "topK": 75,
              "conjunctive": false
            },
            "vector": {
              "enabled": true,
              "topK": 75,
              "efs": 200,
              "indexes": {
                "jina-embeddings-v2-base-code": {
                  "indexName": "symbol_vec_jina_code_v2"
                },
                "nomic-embed-text-v1.5": {
                  "indexName": "symbol_vec_nomic_embed_v15"
                }
              }
            },
            "fusion": {
              "strategy": "rrf",
              "rrfK": 60
            },
            "candidateLimit": 100
          }
        }
      },
      "default": {
        "enabled": true,
        "provider": "local",
        "model": "jina-embeddings-v2-base-code",
        "generateSummaries": false,
        "summaryModel": "claude-haiku-4-5-20251001",
        "summaryMaxConcurrency": 5,
        "summaryBatchSize": 20,
        "embeddingConcurrency": 1
      }
    },
    "prefetch": {
      "type": "object",
      "description": "Predictive prefetch configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "maxBudgetPercent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "warmTopN": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of top-fan-in symbols to prefetch on serve start. Default 0 disables startup warming; raise only when you have evidence the warm set is consumed within the 5-minute stale window."
        }
      },
      "default": {
        "enabled": true,
        "maxBudgetPercent": 20,
        "warmTopN": 0
      }
    },
    "observability": {
      "type": "object",
      "description": "Observability dashboard configuration (in-process metrics + SSE stream)",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "sampleIntervalMs": {
          "type": "integer",
          "minimum": 250,
          "maximum": 60000,
          "default": 2000
        },
        "retentionShortMinutes": {
          "type": "integer",
          "minimum": 1,
          "maximum": 60,
          "default": 15
        },
        "retentionLongHours": {
          "type": "integer",
          "minimum": 1,
          "maximum": 168,
          "default": 24
        },
        "pprMetricsEnabled": {
          "type": "boolean",
          "default": true
        },
        "packedStatsEnabled": {
          "type": "boolean",
          "default": true
        },
        "scipIngestMetrics": {
          "type": "boolean",
          "default": true
        },
        "beamExplainCapacity": {
          "type": "integer",
          "minimum": 8,
          "maximum": 2048,
          "default": 128
        },
        "beamExplainEntriesPerSlice": {
          "type": "integer",
          "minimum": 16,
          "maximum": 8192,
          "default": 512
        },
        "sseHeartbeatMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 60000,
          "default": 15000
        },
        "sseMaxStreamMs": {
          "type": "integer",
          "minimum": 60000,
          "maximum": 86400000,
          "default": 3600000,
          "description": "Maximum lifetime for a single observability SSE stream before the server closes it."
        }
      },
      "default": {
        "enabled": true,
        "sampleIntervalMs": 2000,
        "retentionShortMinutes": 15,
        "retentionLongHours": 24,
        "pprMetricsEnabled": true,
        "packedStatsEnabled": true,
        "scipIngestMetrics": true,
        "beamExplainCapacity": 128,
        "beamExplainEntriesPerSlice": 512,
        "sseHeartbeatMs": 15000,
        "sseMaxStreamMs": 3600000
      }
    },
    "tracing": {
      "type": "object",
      "description": "OpenTelemetry tracing configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable OpenTelemetry tracing",
          "default": true
        },
        "serviceName": {
          "type": "string",
          "description": "Service name for tracing",
          "default": "sdl-mcp"
        },
        "exporterType": {
          "type": "string",
          "description": "Exporter type for traces",
          "enum": ["console", "otlp", "memory"],
          "default": "console"
        },
        "otlpEndpoint": {
          "type": "string",
          "description": "OTLP collector endpoint URL (required when exporterType is otlp)"
        },
        "sampleRate": {
          "type": "number",
          "description": "Sampling rate for traces (0.0 to 1.0)",
          "minimum": 0,
          "maximum": 1,
          "default": 1
        }
      },
      "default": {
        "enabled": true,
        "serviceName": "sdl-mcp",
        "exporterType": "console",
        "sampleRate": 1
      }
    },
    "parallelScorer": {
      "type": "object",
      "description": "Parallel beam search scorer configuration for improved slice performance",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable parallel scoring using worker threads",
          "default": true
        },
        "poolSize": {
          "type": "integer",
          "description": "Number of worker threads in the scorer pool",
          "minimum": 1,
          "maximum": 16
        },
        "minBatchSize": {
          "type": "integer",
          "description": "Minimum candidates to trigger parallel scoring",
          "minimum": 1,
          "maximum": 100
        }
      },
      "default": {
        "enabled": true
      }
    },
    "graphDatabase": {
      "type": "object",
      "description": "LadybugDB graph database configuration for advanced graph queries",
      "properties": {
        "path": {
          "type": ["string", "null"],
          "description": "Path to the LadybugDB database file",
          "default": null
        }
      }
    },
    "concurrency": {
      "type": "object",
      "description": "Concurrency settings for multi-agent access",
      "properties": {
        "maxSessions": {
          "type": "integer",
          "description": "Maximum number of concurrent MCP sessions",
          "minimum": 1,
          "maximum": 32,
          "default": 8
        },
        "maxToolConcurrency": {
          "type": "integer",
          "description": "Maximum concurrent tool handler executions across all sessions",
          "minimum": 1,
          "maximum": 64,
          "default": 8
        },
        "readPoolSize": {
          "type": "integer",
          "description": "Number of read-only database connections in the pool",
          "minimum": 1,
          "maximum": 16,
          "default": 4
        },
        "writeQueueTimeoutMs": {
          "type": "integer",
          "description": "Timeout for queued write operations in milliseconds",
          "minimum": 1000,
          "maximum": 120000,
          "default": 30000
        },
        "toolQueueTimeoutMs": {
          "type": "integer",
          "description": "Timeout for queued tool dispatch operations in milliseconds",
          "minimum": 5000,
          "maximum": 120000,
          "default": 30000
        }
      },
      "default": {
        "maxSessions": 8,
        "maxToolConcurrency": 8,
        "readPoolSize": 4,
        "writeQueueTimeoutMs": 30000,
        "toolQueueTimeoutMs": 30000
      }
    },
    "runtime": {
      "type": "object",
      "description": "Runtime execution tool configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable the runtime execution tool",
          "default": false
        },
        "allowedRuntimes": {
          "type": "array",
          "description": "List of allowed runtime environments",
          "items": { "type": "string" },
          "default": ["node", "python"]
        },
        "allowedExecutables": {
          "type": "array",
          "description": "List of allowed executable paths or patterns",
          "items": { "type": "string" },
          "default": []
        },
        "maxDurationMs": {
          "type": "integer",
          "description": "Maximum execution duration in milliseconds",
          "minimum": 1000,
          "maximum": 600000,
          "default": 30000
        },
        "maxStdoutBytes": {
          "type": "integer",
          "description": "Maximum stdout capture size in bytes",
          "minimum": 1024,
          "default": 1048576
        },
        "maxStderrBytes": {
          "type": "integer",
          "description": "Maximum stderr capture size in bytes",
          "minimum": 1024,
          "default": 524288
        },
        "maxArtifactBytes": {
          "type": "integer",
          "description": "Maximum artifact file size in bytes",
          "minimum": 1024,
          "default": 10485760
        },
        "artifactTtlHours": {
          "type": "integer",
          "description": "Time-to-live for stored artifacts in hours",
          "minimum": 1,
          "default": 24
        },
        "maxConcurrentJobs": {
          "type": "integer",
          "description": "Maximum concurrent runtime executions",
          "minimum": 1,
          "maximum": 12,
          "default": 2
        },
        "envAllowlist": {
          "type": "array",
          "description": "Environment variable names to pass through to sandboxed subprocesses",
          "items": { "type": "string" },
          "default": []
        }
      },
      "default": {
        "enabled": true,
        "allowedRuntimes": ["node", "typescript", "python", "shell"],
        "allowedExecutables": [],
        "maxDurationMs": 30000,
        "maxConcurrentJobs": 2,
        "envAllowlist": []
      }
    },
    "security": {
      "type": "object",
      "description": "Access control configuration",
      "properties": {
        "allowedRepoRoots": {
          "type": "array",
          "description": "Whitelist of allowed repository root path prefixes. Empty array allows any path.",
          "items": { "type": "string" },
          "default": []
        }
      },
      "default": {
        "allowedRepoRoots": []
      }
    },
    "gateway": {
      "type": "object",
      "description": "Tool gateway configuration — collapse 25+ tools into 4 namespace-scoped gateway tools to reduce system-prompt token overhead",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable gateway mode (4 tools instead of 25+)",
          "default": true
        },
        "emitLegacyTools": {
          "type": "boolean",
          "description": "When gateway is enabled, also register the 25 legacy tool names for backward compatibility. Deprecated: will be removed in a future version.",
          "default": false
        }
      },
      "default": {
        "enabled": true,
        "emitLegacyTools": false
      }
    },
    "httpAuth": {
      "type": "object",
      "description": "HTTP transport authentication configuration — set a static bearer token or disable auth entirely",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable bearer-token authentication for /mcp and /api/* endpoints",
          "default": false
        },
        "token": {
          "type": ["string", "null"],
          "description": "Static bearer token. When null a random token is generated at startup.",
          "minLength": 1,
          "default": null
        },
        "rateLimit": {
          "type": "object",
          "description": "Per-client token bucket for protected HTTP routes before bearer-token comparison",
          "properties": {
            "bucketSize": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10000,
              "default": 30
            },
            "refillPerSec": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 1000,
              "default": 0.5
            }
          },
          "default": {
            "bucketSize": 30,
            "refillPerSec": 0.5
          }
        }
      },
      "default": {
        "enabled": false,
        "token": null,
        "rateLimit": {
          "bucketSize": 30,
          "refillPerSec": 0.5
        }
      }
    },
    "http": {
      "type": "object",
      "description": "HTTP transport bind configuration.",
      "additionalProperties": false,
      "properties": {
        "allowRemote": {
          "type": "boolean",
          "description": "Allow binding the HTTP transport to a non-loopback host such as 0.0.0.0 or ::.",
          "default": false
        }
      },
      "default": {
        "allowRemote": false
      }
    },
    "codeMode": {
      "type": "object",
      "description": "Code Mode configuration — batch multiple tool calls in a single workflow with $N references between steps",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Code Mode tools (sdl.manual + sdl.workflow + sdl.context + sdl.file)",
          "default": true
        },
        "exclusive": {
          "type": "boolean",
          "description": "When true, suppress gateway and legacy tools — only register code-mode tools",
          "default": true
        },
        "maxWorkflowSteps": {
          "type": "integer",
          "description": "Maximum steps allowed in a single workflow",
          "minimum": 1,
          "maximum": 50,
          "default": 20
        },
        "maxWorkflowTokens": {
          "type": "integer",
          "description": "Maximum total estimated tokens for workflow results",
          "minimum": 100,
          "maximum": 500000,
          "default": 50000
        },
        "maxWorkflowDurationMs": {
          "type": "integer",
          "description": "Maximum wall-clock duration for a workflow in milliseconds",
          "minimum": 1000,
          "maximum": 300000,
          "default": 60000
        },
        "ladderValidation": {
          "type": "string",
          "enum": ["off", "warn", "enforce"],
          "description": "Context ladder validation mode",
          "default": "warn"
        },
        "etagCaching": {
          "type": "boolean",
          "description": "Auto-inject ifNoneMatch ETags for repeated symbol card requests within a workflow",
          "default": true
        }
      },
      "default": {
        "enabled": true,
        "exclusive": true
      }
    },
    "scip": {
      "type": "object",
      "description": "SCIP index ingestion configuration",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "indexes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "label": { "type": "string" }
            },
            "required": ["path"]
          },
          "default": []
        },
        "externalSymbols": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "maxPerIndex": {
              "type": "integer",
              "minimum": 100,
              "maximum": 100000,
              "default": 10000
            }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 1.0,
          "default": 0.95
        },
        "autoIngestOnRefresh": { "type": "boolean", "default": true },
        "ingestConcurrency": {
          "type": "integer",
          "description": "Number of SCIP indexes to ingest concurrently. Decode/parse overlaps; writes still serialise via writeLimiter. Default 1 (sequential).",
          "minimum": 1,
          "maximum": 8,
          "default": 1
        },
        "generator": {
          "type": "object",
          "description": "Auto-generate index.scip via the scip-io CLI before each refresh. Has no effect unless scip.enabled is also true. When enabled and the binary is missing, sdl-mcp downloads it from GitHub releases into ~/.sdl-mcp/bin/ with mandatory SHA-256 verification against the release's SHA256SUMS.txt; installs are refused if the checksum file is absent.",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "binary": { "type": "string", "default": "scip-io" },
            "args": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            },
            "autoInstall": { "type": "boolean", "default": true },
            "timeoutMs": {
              "type": "integer",
              "minimum": 1000,
              "maximum": 1800000,
              "default": 600000
            },
            "cleanupAfterIngest": {
              "type": "boolean",
              "description": "Delete <repoRoot>/index.scip after the post-refresh ingest consumes it. The file is regenerated every refresh, so keeping it just clutters the working tree. Only the default output location is cleaned up — passing --output via args opts you out of cleanup automatically.",
              "default": true
            }
          },
          "default": {
            "enabled": false,
            "binary": "scip-io",
            "args": [],
            "autoInstall": true,
            "timeoutMs": 600000,
            "cleanupAfterIngest": true
          }
        }
      }
    },
    "memory": {
      "type": "object",
      "description": "Memory subsystem configuration. Memory is disabled by default.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Master enable for the memory subsystem. When false, all memory features are disabled.",
          "default": false
        },
        "toolsEnabled": {
          "type": "boolean",
          "description": "Enable memory CRUD tools (store, query, remove, surface)",
          "default": true
        },
        "fileSyncEnabled": {
          "type": "boolean",
          "description": "Enable .sdl-memory file read/import/write/delete",
          "default": true
        },
        "surfacingEnabled": {
          "type": "boolean",
          "description": "Enable memory injection into repo.status and slice.build",
          "default": true
        },
        "hintsEnabled": {
          "type": "boolean",
          "description": "Enable _memoryHint post-dispatch guidance",
          "default": true
        },
        "defaultSurfaceLimit": {
          "type": "integer",
          "description": "Default number of memories to surface when limit is omitted",
          "default": 5,
          "minimum": 1,
          "maximum": 50
        }
      },
      "additionalProperties": false
    },
    "wire": {
      "type": "object",
      "description": "Wire-format configuration (packed, auto-gate)",
      "properties": {
        "packed": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Master switch for packed wire format. Env var SDL_PACKED_ENABLED overrides.",
              "default": true
            },
            "threshold": {
              "type": "number",
              "description": "Minimum byte-savings ratio before packed payload is emitted (0.0-1.0). Env var SDL_PACKED_THRESHOLD overrides.",
              "default": 0.1,
              "minimum": 0,
              "maximum": 1
            },
            "tokenThreshold": {
              "type": "number",
              "description": "Minimum estimated-token-savings ratio before packed payload is emitted (0.0-1.0). Either threshold (bytes OR tokens) is sufficient. Env var SDL_PACKED_TOKEN_THRESHOLD overrides.",
              "default": 0.2,
              "minimum": 0,
              "maximum": 1
            },
            "defaultFormat": {
              "type": "string",
              "enum": ["packed", "auto", "compact"],
              "description": "Default wire format when client omits the field. Env var SDL_PACKED_DEFAULT_FORMAT overrides.",
              "default": "auto"
            },
            "encoders": {
              "type": "object",
              "description": "Per-encoder enable map keyed by encoderId (sl1, ss1, ctx1)",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean", "default": true }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
