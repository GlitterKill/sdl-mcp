{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": false,
    "rootDir": "./",
    "outDir": "./dist",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true
  },
  "include": [
    "scripts/build-exe.ts",
    "scripts/migrate.ts",
    "scripts/index-repo.ts",
    "scripts/dump-symbol.ts",
    "tests/harness/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
