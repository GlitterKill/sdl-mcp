{
  "name": "sdl-mcp-native",
  "version": "0.10.3",
  "description": "Native Rust indexer for SDL-MCP with tree-sitter parsing and Rayon parallelism",
  "license": "SEE LICENSE IN LICENSE",
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "name": "sdl-mcp-native",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-pc-windows-msvc",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "scripts": {
    "build": "napi build --release --cargo-cwd . --config package.json .",
    "artifacts": "napi artifacts",
    "version": "napi version"
  },
  "optionalDependencies": {
    "sdl-mcp-native-win32-x64-msvc": "0.10.3",
    "sdl-mcp-native-darwin-x64": "0.10.3",
    "sdl-mcp-native-darwin-arm64": "0.10.3",
    "sdl-mcp-native-linux-x64-gnu": "0.10.3",
    "sdl-mcp-native-linux-x64-musl": "0.10.3",
    "sdl-mcp-native-linux-arm64-gnu": "0.10.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlitterKill/sdl-mcp.git",
    "directory": "native"
  }
}
